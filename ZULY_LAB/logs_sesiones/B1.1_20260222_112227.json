    {
      "numero": 2,
      "action": "run_python_script",
      "params": {
        "script_content": "import math\n\n# Parámetros de la hélice\nnum_pares = 20\naltura_total = 10.0\nradio_helice = 2.0\nvueltas = 2.0\n\n# Materiales (crearlos primero usando el adapter disponible en el contexto)\nadapter.create_material(name=\"MatBaseA\", color=[1.0, 0.2, 0.2, 1.0]) # Rojo\nadapter.create_material(name=\"MatBaseB\", color=[0.2, 0.2, 1.0, 1.0]) # Azul\nadapter.create_material(name=\"MatPuente\", color=[1.0, 1.0, 1.0, 1.0]) # Blanco\n\nfor i in range(num_pares):\n    t = i / num_pares\n    angulo = t * vueltas * 2 * math.pi\n    z = (t * altura_total) - (altura_total / 2)\n    \n    x = math.cos(angulo) * radio_helice\n    y = math.sin(angulo) * radio_helice\n    \n    # Esfera Cadena A\n    adapter.create_primitive(\n        'sphere', \n        location=[x, y, z], \n        radius=0.3, \n        name=f\"BaseA_{i}\"\n    )\n    adapter.apply_material(f\"BaseA_{i}\", \"MatBaseA\")\n    \n    # Esfera Cadena B (opuesta)\n    adapter.create_primitive(\n        'sphere', \n        location=[-x, -y, z], \n        radius=0.3, \n        name=f\"BaseB_{i}\"\n    )\n    adapter.apply_material(f\"BaseB_{i}\", \"MatBaseB\")\n    \n    # Puente (Cilindro conector)\n    # Calculamos rotación para alinear... o simplificamos usando cubos estirados\n    # Para simplificar matemática de rotación en esta fase inicial, usamos un cubo muy delgado\n    adapter.create_primitive(\n        'cube',\n        location=[0, 0, z],\n        scale=[radio_helice, 0.1, 0.1], # Largo en X, delgado en Y/Z\n        name=f\"Puente_{i}\"\n    )\n    # Rotar el puente para que coincida con el ángulo\n    # El cubo base está en X. Rotamos en Z.\n    adapter.rotate_object(f\"Puente_{i}\", [0, 0, angulo])\n    adapter.apply_material(f\"Puente_{i}\", \"MatPuente\")\n"
      },
      "exito": true,
